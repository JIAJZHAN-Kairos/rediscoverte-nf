/*
 * REdiscoverTE-nf default config
 *
 * IMPORTANT: replace JIAJZHAN-Kairos below with your GitHub username
 * before pushing containers, or override container paths via -c custom.config
 */

manifest {
    name            = 'rediscoverte-nf'
    author          = 'Jiajun Zhan'
    description     = 'REdiscoverTE quantification (Salmon + rollup) for RNA-seq'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}

params {
    // Inputs
    input             = null   // path to samplesheet.csv
    outdir            = './results'

    // References
    salmon_index      = null   // path to prebuilt REdiscoverTE Salmon index dir
    rollup_annotation = null   // path to REdiscoverTE rollup_annotation/ dir
    assembly          = 'hg38'

    // Behaviour
    salmon_libtype    = 'A'    // auto-detect
    rollup_nozero     = true
}

process {
    // sensible defaults; per-process overrides below
    cpus   = 4
    memory = 8.GB
    time   = 4.h
    errorStrategy = { task.exitStatus in [137,143] ? 'retry' : 'finish' }
    maxRetries    = 1

    withName: ORA_DECOMPRESS {
        container = 'ghcr.io/JIAJZHAN-Kairos/rediscoverte-orad:2.7.0'
        cpus      = 8
        memory    = 16.GB
        time      = 4.h
    }
    withName: SALMON_QUANT {
        container = 'quay.io/biocontainers/salmon:1.10.3--h6dccd9a_2'
        cpus      = 8
        memory    = 32.GB
        time      = 6.h
    }
    withName: ROLLUP {
        container = 'ghcr.io/JIAJZHAN-Kairos/rediscoverte-rollup:1.0'
        cpus      = 8
        memory    = 64.GB
        time      = 8.h
    }
}

profiles {
    standard {
        docker.enabled = true
    }
    docker {
        docker.enabled = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    awsbatch {
        // Set queue + workDir at launch via -c or Seqera UI
        process.executor = 'awsbatch'
        aws.region       = 'ap-southeast-2'
    }
    test {
        docker.enabled = true
        params.input             = "${projectDir}/assets/samplesheet.example.csv"
        params.outdir            = './test_results'
    }
}

// Reports
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}
