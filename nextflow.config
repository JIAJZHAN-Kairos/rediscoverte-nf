/*
 * REdiscoverTE-nf default config
 *
 * IMPORTANT: override container params at launch if your GHCR images are
 * pushed under a different namespace.
 */

manifest {
    name            = 'rediscoverte-nf'
    author          = 'Jiajun Zhan'
    description     = 'REdiscoverTE quantification (Salmon + rollup) for RNA-seq'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '0.1.0'
}

params {
    // Inputs
    input             = null   // path to samplesheet.csv
    outdir            = './results'

    // References
    salmon_index      = null   // path to prebuilt REdiscoverTE Salmon index dir
    transcriptome_fasta = null // optional FASTA/FASTA.gz/FASTA.xz to build Salmon index at runtime
    rollup_annotation = null   // path to REdiscoverTE rollup_annotation/ dir
    assembly          = 'hg38'

    // Behaviour
    salmon_libtype    = 'A'    // auto-detect
    index_kmer        = 31
    rollup_nozero     = true

    // Containers
    orad_container     = 'ghcr.io/jiajzhan-kairos/rediscoverte-orad:2.7.0'
    salmon_container   = 'quay.io/biocontainers/salmon:1.10.3--h6dccd9a_2'
    rollup_container   = 'ghcr.io/jiajzhan-kairos/rediscoverte-rollup:1.0'

    // Seqera / AWS Batch overrides
    awsregion          = 'ap-southeast-2'
    publish_mode       = 'copy'
}

process {
    // sensible defaults; per-process overrides below
    cpus   = 4
    memory = 8.GB
    time   = 4.h
    errorStrategy = { task.exitStatus in [137,143] ? 'retry' : 'finish' }
    maxRetries    = 1

    withName: ORA_DECOMPRESS {
        container = params.orad_container
        cpus      = 8
        memory    = 16.GB
        time      = 4.h
    }
    withName: SALMON_QUANT {
        container = params.salmon_container
        cpus      = 16
        memory    = 128.GB
        time      = 12.h
    }
    withName: BUILD_SALMON_INDEX {
        container = params.salmon_container
        cpus      = 64
        memory    = 96.GB
        time      = 12.h
    }
    withName: ROLLUP {
        container = params.rollup_container
        cpus      = 8
        memory    = 64.GB
        time      = 8.h
    }
}

profiles {
    standard {
        docker.enabled = true
    }
    docker {
        docker.enabled = true
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    awsbatch {
        // Set queue + workDir at launch via -c or Seqera UI
        process.executor = 'awsbatch'
        aws.region       = params.awsregion
        docker.enabled   = true
    }
    seqera {
        process.executor = 'awsbatch'
        aws.region       = params.awsregion
        docker.enabled   = true
    }
    test {
        docker.enabled = true
        params.input             = "${projectDir}/assets/samplesheet.example.csv"
        params.outdir            = './test_results'
    }
}

// Reports
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}
